#!/usr/bin/env bash
#
# Run Jekyll in production-parity mode

set -e

HOST="0.0.0.0"
PORT=4000

# Check bundle is available
if ! command -v bundle >/dev/null 2>&1; then
    echo "[!] 'bundle' not found. Install Ruby and Bundler first."
    exit 1
fi

# Check npm deps have been installed
if [[ ! -d node_modules ]]; then
    echo "[!] node_modules/ not found. Run './scripts/setup' first."
    exit 1
fi

# Check JS assets have been built
if [[ ! -d assets/js/dist ]] || [[ -z "$(ls -A assets/js/dist 2>/dev/null)" ]]; then
    echo "[!] assets/js/dist/ is empty. Run './scripts/setup' first."
    exit 1
fi

# Check Ruby gems have been installed
if ! bundle check >/dev/null 2>&1; then
    echo "[!] Ruby gems are not installed. Run './scripts/setup' first."
    exit 1
fi

echo "[*] Production-parity server: http://$(hostname -I | tr -d ' ' | awk '{print $1}'):${PORT}"
echo "[*] Environment: production"
echo "[*] Drafts: disabled"

JEKYLL_ENV=production bundle exec jekyll s -H "${HOST}" -P "${PORT}" "$@"
